<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HomeAway</title>
    <link rel="stylesheet" href="/css/listings/index.css" />
  </head>
  <body>
    <!-- ---------- Header ---------- -->
    <header class="header">
      <div class="logo">
        <img src="/images/logo.png" alt="logo.png" />
        <a href="http://localhost:8080/listings">homeAway</a>
      </div>

      <!-- Placeholder for future nav items -->
      <nav class="nav">
        <!-- Example: <a href="#">Login</a> <a href="#">Sign Up</a> -->
        <a href="http://localhost:8080/listings/new">Become a host</a>
      </nav>
    </header>

    <!-- ---------- Main Content ---------- -->
    <main class="content">
      <div class="container-box">
        <% data.forEach(item => { %>
        <div class="item-card">
          <a href="http://localhost:8080/listings/view/<%= item._id %>">
            <img
              class="item-image"
              src="<%= item.image.url %>"
              alt="<%= item.title %> image"
            />
          </a>
          <div class="item-details">
            <a
              class="item-title"
              href="http://localhost:8080/listings/view/<%= item._id %>"
              ><%= item.title %> in <%= item.location %></a
            >
            <span class="item-price"><%= item.price %> for 1 night stay</span>
          </div>
        </div>
        <% }) %>
      </div>
    </main>
  </body>
</html>
