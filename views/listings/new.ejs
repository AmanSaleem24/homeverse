<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Listing</title>
    <link rel="stylesheet" href="/css/listings/new.css" />
  </head>
  <body>
    <header class="header">
      <div class="logo">
        <img src="/images/logo.png" alt="homeAway logo" />
        <a href="http://localhost:8080/listings">homeAway</a>
      </div>
      <nav class="nav">
        <a href="http://localhost:8080/listings/new">Become a host</a>
      </nav>
    </header>
    <div class="form-container">
      <h1>Add your place to homeAway</h1>
      <h2>Fill in the details below to register yourself.</h2>

      <form action="http://localhost:8080/listings/new" method="POST">
        <!-- Title -->
        <label for="title">Title</label>
        <input type="text" name="title" id="title" placeholder="Title" />

        <!-- Description -->
        <label for="description">Description</label>
        <textarea
          name="description"
          id="description"
          placeholder="Description"
        ></textarea>

        <!-- Image fields in a row -->
        <div class="form-row">
          <div>
            <label for="filename">Image Filename</label>
            <input type="text" name="filename" id="filename" />
          </div>
          <div>
            <label for="url">Image URL</label>
            <input type="text" name="url" id="url" />
          </div>
        </div>

        <!-- Price -->
        <label for="price">Price (₹)</label>
        <input type="text" name="price" id="price" placeholder="Price" />

        <!-- Location + Country in a row -->
        <div class="form-row">
          <div>
            <label for="location">Location</label>
            <input type="text" name="location" id="location" />
          </div>
          <div>
            <label for="country">Country</label>
            <input type="text" name="country" id="country" />
          </div>
        </div>

        <button type="submit">Submit</button>
      </form>
    </div>
  </body>
</html>
